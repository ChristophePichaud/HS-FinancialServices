// HSClientApp.rc
// Resource script for the HS Financial Services MFC client application.
//
// Dialog layout (all coordinates in Dialog Units, 9pt Segoe UI font):
//
//   ┌─────────────────────────────────────────────────────────────┐
//   │  HS Financial Services – Client Test Application            │
//   ├─────────────────────────────────────────────────────────────┤
//   │ ● Connection ─────────────────────────────────────────────  │
//   │   Host: [127.0.0.1      ] Port: [9000] [Connect][Disconnect]│
//   │   Status: ⬤ Disconnected                                    │
//   ├─────────────────────────────────────────────────────────────┤
//   │ ● Command ────────────────────────────────────────────────  │
//   │   [Select a command...  ▼                          ] [ Run ] │
//   ├─────────────────────────────────────────────────────────────┤
//   │ ● Output ─────────────────────────────────────────────────  │
//   │   ┌───────────────────────────────────────────────────────┐ │
//   │   │ (multi-line, scrollable output)                       │ │
//   │   └───────────────────────────────────────────────────────┘ │
//   │                                           [ Clear Output ]  │
//   └─────────────────────────────────────────────────────────────┘

#include "resource.h"

// ── Numeric constant (keep rc.exe happy) ────────────────────────────────────
#ifndef IDC_STATIC
#define IDC_STATIC (-1)
#endif

// ── Version / character-set info ────────────────────────────────────────────
LANGUAGE 0x9, 0x1   // LANG_ENGLISH, SUBLANG_DEFAULT

// ── Main dialog ─────────────────────────────────────────────────────────────
IDD_MAIN_DIALOG DIALOGEX 0, 0, 550, 420
CAPTION "HS Financial Services \x2013 Client Test Application"
FONT 9, "Segoe UI", 400, 0, 0x1
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU | WS_MINIMIZEBOX
BEGIN
    // ── Connection group ─────────────────────────────────────────────────
    GROUPBOX        "Connection",         IDC_STATIC,         7,   7, 536,  54

    LTEXT           "Host:",              IDC_STATIC,        15,  22,  22,  10
    EDITTEXT                              IDC_EDIT_HOST,     39,  20, 150,  14,
                    ES_AUTOHSCROLL

    LTEXT           "Port:",              IDC_STATIC,       197,  22,  20,  10
    EDITTEXT                              IDC_EDIT_PORT,    219,  20,  50,  14,
                    ES_AUTOHSCROLL | ES_NUMBER

    PUSHBUTTON      "Connect",            IDC_BTN_CONNECT,  278,  18,  65,  16
    PUSHBUTTON      "Disconnect",         IDC_BTN_DISCONNECT,350, 18,  75,  16

    LTEXT           "Status:",            IDC_STATIC,        15,  42,  28,  10
    LTEXT           "\x25CF  Disconnected", IDC_STATIC_STATUS, 45, 42, 490,  10

    // ── Command group ────────────────────────────────────────────────────
    GROUPBOX        "Command",            IDC_STATIC,         7,  67, 536,  34

    COMBOBOX                              IDC_COMBO_COMMANDS, 15,  79, 430, 200,
                    CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    PUSHBUTTON      "Run",                IDC_BTN_RUN,      452,  77,  84,  18

    // ── Output group ─────────────────────────────────────────────────────
    GROUPBOX        "Output",             IDC_STATIC,         7, 107, 536, 307

    EDITTEXT                              IDC_EDIT_OUTPUT,   15, 120, 520, 278,
                    ES_MULTILINE | ES_AUTOVSCROLL | ES_READONLY |
                    WS_VSCROLL | WS_HSCROLL | WS_TABSTOP

    PUSHBUTTON      "Clear Output",       IDC_BTN_CLEAR,    454, 402,  86,  14
END
